{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "disable": false,
      "permission": {
        "bash": {
          "*": "ask",
          "git diff*": "allow",
          "git log*": "allow",
          "git status*": "allow"
        },
        "edit": "ask"
      }
    },
    "code-review-analysis": {
      "description": "Analysis half of code review — findings grouped by concern, code snippets, assessment.",
      "mode": "subagent",
      "permission": {
        "bash": {
          "*": "deny",
          "gh pr diff*": "allow",
          "gh pr view*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git rev-parse*": "allow",
          "git show*": "allow",
          "git status*": "allow"
        }
      },
      "prompt": "{file:./prompts/code-review-analysis.md}",
      "temperature": 0.1,
      "tools": {
        "*": false,
        "bash": true,
        "glob": true,
        "grep": true,
        "read": true
      }
    },
    "code-review-comprehension": {
      "description": "Comprehension half of code review — explains changeset via summary, flow diagram, walkthrough.",
      "mode": "subagent",
      "permission": {
        "bash": {
          "*": "deny",
          "gh pr diff*": "allow",
          "gh pr view*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git rev-parse*": "allow",
          "git show*": "allow",
          "git status*": "allow"
        }
      },
      "prompt": "{file:./prompts/code-review-comprehension.md}",
      "temperature": 0.1,
      "tools": {
        "*": false,
        "bash": true,
        "glob": true,
        "grep": true,
        "read": true
      }
    },
    "code-reviewer": {
      "description": "Read-only code review subagent with restricted tool access",
      "mode": "subagent",
      "permission": {
        "bash": {
          "*": "deny",
          "gh pr diff*": "allow",
          "gh pr view*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "git rev-parse*": "allow",
          "git show*": "allow",
          "git status*": "allow",
          "mkdir -p .dk-notes/reviews*": "allow"
        }
      },
      "prompt": "{file:./prompts/code-reviewer.md}",
      "temperature": 0.1,
      "tools": {
        "*": false,
        "bash": true,
        "glob": true,
        "grep": true,
        "read": true,
        "save-code-review": true
      }
    },
    "explainer": {
      "description": "Subagent that generates visual HTML explanations with diagrams and quizzes",
      "mode": "subagent",
      "prompt": "{file:./prompts/explainer.md}",
      "temperature": 0.1,
      "tools": {
        "*": false,
        "glob": true,
        "grep": true,
        "read": true,
        "save-explanation": true
      }
    },
    "git-committer": {
      "description": "Subagent that commits staged changes with a conventional commit message",
      "mode": "subagent",
      "permission": {
        "bash": {
          "*": "deny",
          "git commit*": "allow",
          "git diff*": "allow",
          "git status*": "allow"
        }
      },
      "prompt": "{file:./prompts/git-committer.md}",
      "temperature": 0.1,
      "tools": {
        "*": false,
        "bash": true
      }
    },
    "git-stasher": {
      "description": "Subagent that stashes changes with a meaningful name",
      "mode": "subagent",
      "permission": {
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "git stash*": "allow",
          "git status*": "allow"
        }
      },
      "prompt": "{file:./prompts/git-stasher.md}",
      "temperature": 0.1,
      "tools": {
        "*": false,
        "bash": true
      }
    },
    "plan": {
      "disable": false
    },
    "pr-describer": {
      "description": "Subagent that reads PR changes and writes a title and description",
      "mode": "subagent",
      "prompt": "{file:./prompts/pr-describer.md}",
      "temperature": 0.1,
      "tools": {
        "*": false,
        "read-pr-info": true,
        "update-pr-info": true
      }
    },
    "tutor": {
      "description": "tutor based on https://www.theneuron.ai/explainer-articles/your-brain-on-ai-is-literally-shrinking-and-how-to-fix-it",
      "mode": "primary",
      "prompt": "{file:./prompts/tutor.md}",
      "temperature": 0.1,
      "tools": {
        "*": false,
        "glob": true,
        "grep": true,
        "read": true,
        "webfetch": true
      }
    },
    "yolo": {
      "description": "Agent that auto-accepts all edits and bash",
      "mode": "primary",
      "permission": {
        "bash": "allow",
        "edit": "allow"
      }
    }
  },
  "mcp": {
    "btca-local": {
      "command": [
        "bunx",
        "btca",
        "mcp"
      ],
      "enabled": true,
      "type": "local"
    },
    "context7": {
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "model": "github-copilot/claude-sonnet",
  "plugin": [
    "@plannotator/opencode@latest",
    "opencode-claude-bridge@latest",
    "@mohak34/opencode-notifier@0.2.1"
  ],
  "provider": {
    "lmstudio": {
      "models": {
        "google/gemma-4-26b-a4b": {
          "limit": {
            "context": 124300,
            "output": 8192
          },
          "name": "Gemma 4 26B A4B"
        }
      },
      "name": "LM Studio (local)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:1234/v1"
      }
    }
  }
}
