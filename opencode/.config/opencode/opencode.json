{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/claude-sonnet",
  "agent": {
    "build": {
      "disable": false
    },
    "plan": {
      "disable": false
    },
    "tutor": {
      "mode": "primary",
      "description": "tutor based on https://www.theneuron.ai/explainer-articles/your-brain-on-ai-is-literally-shrinking-and-how-to-fix-it",
      "prompt": "{file:./prompts/tutor.md}",
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false,
        "webfetch": true
      }
    },
    "investigator": {
      "mode": "primary",
      "prompt": "{file:./prompts/investigator.md}",
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "bash": true,
        "webfetch": true
      }
    },
    "code-reviewer": {
      "description": "Read-only code review subagent with restricted tool access",
      "mode": "subagent",
      "prompt": "{file:./prompts/code-reviewer.md}",
      "temperature": 0.1,
      "tools": {
        "write": false,
        "edit": false,
        "webfetch": false,
        "context7_*": false,
        "btca-local_*": false
      },
      "permission": {
        "bash": {
          "*": "deny",
          "git diff*": "allow",
          "git log*": "allow",
          "git status*": "allow",
          "git rev-parse*": "allow",
          "git show*": "allow",
          "gh pr view*": "allow",
          "gh pr diff*": "allow"
        }
      }
    },
    "pr-describer": {
      "description": "Subagent that reads PR changes and writes a title and description",
      "mode": "subagent",
      "prompt": "{file:./prompts/pr-describer.md}",
      "temperature": 0.1,
      "tools": {
        "read": false,
        "write": false,
        "edit": false,
        "glob": false,
        "grep": false,
        "bash": false,
        "webfetch": false,
        "context7_*": false,
        "btca-local_*": false,
        "save-code-review": false,
        "submit-pr-comment": false,
        "read-pr-info": true,
        "update-pr-info": true
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true
    },
    "btca-local": {
      "type": "local",
      "command": [
        "bunx",
        "btca",
        "mcp"
      ],
      "enabled": true
    }
  },
  "plugin": [
    "@plannotator/opencode@latest",
    "opencode-claude-bridge"
  ]
}
