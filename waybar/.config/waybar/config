{
    "layer": "top",
    "position": "top",
    "height": 32,
    "spacing": 4,
    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window"
    ],
    "modules-center": [
        "hyprland/mode"
    ],
    "modules-right": [
        "custom/network",
        "battery",
        "custom/power-profiles",
        "disk",
        "cpu",
        "memory",
        "pulseaudio",
        "backlight",
        "custom/hyprshade",
        "clock",
        "tray"
    ],
    "hyprland/workspaces": {
        "disable-scroll": false,
        "all-outputs": true,
        "format": "{icon} {name}",
        "format-icons": {
            "default": "п„‘",
            "active": "п†’",
            "urgent": "пЃ±"
        },
        "tooltip-format": "Workspace {name}"
    },
    "hyprland/window": {
        "format": "{}",
        "max_length": 60,
        "separate-outputs": false,
        "tooltip": false
    },
    "hyprland/mode": {
        "format": "{}",
        "tooltip": false
    },
    "custom/network": {
        "exec": "sh -c '$HOME/.local/bin/waybar-network'",
        "return-type": "json",
        "on-click": "nm-connection-editor",
        "interval": 5,
        "tooltip": true
    },
    "battery": {
        "bat": "BAT0",
        "states": {
            "good": 80,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}% {time}",
        "format-charging": "у°‚„ {capacity}% {time}",
        "format-discharging": "{icon} {capacity}% {time}",
        "format-plugged": "у°‚„ {capacity}%",
        "format-full": "у°Ѓ№ 100%",
        "format-icons": [
            "у°‚Ћ",
            "у°Ѓј",
            "у°Ѓѕ",
            "у°Ѓї",
            "у°‚Ђ",
            "у°‚Ѓ",
            "у°‚‚",
            "у°Ѓ№"
        ],
        "tooltip-format": "Battery\n{timeTo}\n{capacity}%"
    },
    "custom/power-profiles": {
        "exec": "sh -c '$HOME/.local/bin/power-profiles-ctl status'",
        "return-type": "json",
        "on-click": "sh -c '$HOME/.local/bin/power-profiles-ctl toggle'",
        "on-scroll-up": "sh -c '$HOME/.local/bin/power-profiles-ctl scroll-up'",
        "on-scroll-down": "sh -c '$HOME/.local/bin/power-profiles-ctl scroll-down'",
        "interval": 5,
        "tooltip": true
    },
    "disk": {
        "path": "/",
        "format": "у°‹Љ {free}",
        "interval": 30,
        "tooltip-format": "Disk\n{free} free of {total}"
    },
    "cpu": {
        "format": "у°Ќ› {load}",
        "tooltip-format": "CPU\n{usage}% @ {freq}GHz",
        "on-click": "ghostty -e btop"
    },
    "memory": {
        "format": "у°ѕ№ {used}/{avail}",
        "interval": 10,
        "tooltip-format": "Memory\n{used} used / {avail} free",
        "on-click": "ghostty -e btop"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon} {volume}%",
        "format-muted": "у°ќџ muted",
        "format-icons": {
            "headphone": "у°‹‹",
            "default": [
                "у°•ї",
                "у°–Ђ",
                "у°•ѕ"
            ]
        },
        "scroll-step": 0.5,
        "on-click": "pavucontrol",
        "on-right-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "tooltip-format": "Audio\n{desc}\n{volume}%"
    },
    "backlight": {
        "device": "intel_backlight",
        "format": "у°ѓЁ {percent}%",
        "on-scroll-up": "brightnessctl set 1%+",
        "on-scroll-down": "brightnessctl set 1%-",
        "tooltip-format": "Brightness\n{percent}%"
    },
        "custom/hyprshade": {
            "exec": "sh -c '$HOME/.local/bin/hyprshade-ctl status'",
            "return-type": "json",
            "on-click": "sh -c '$HOME/.local/bin/hyprshade-ctl toggle'",
            "interval": 5,
            "tooltip": true
        },
    "clock": {
        "format": "у°Ґ” {:%a %d %b  %H:%M}",
        "format-alt": "у°Ґ” {:%Y-%m-%d %H:%M:%S}",
        "interval": 5,
        "tooltip": false,
        "on-click": "XDG_CURRENT_DESKTOP=GNOME gnome-calendar"
    },
    "tray": {
        "spacing": 6,
        "icon-size": 16,
        "tooltip-format": "System tray"
    }
}