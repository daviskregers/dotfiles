#!/usr/bin/env bash
# yoinked from https://raw.githubusercontent.com/ThePrimeagen/.dotfiles/master/bin/.local/scripts/tmux-sessionizer

if [[ $# -eq 1 ]]; then
    selected=$1
else
    # Read patterns from .tsp file, ignoring comments and empty lines
    tsp_file="$HOME/.tsp"
    default_directories=""
    extra_paths=""

    if [[ -f "$tsp_file" ]]; then
        while IFS= read -r line; do
            # Skip comments and empty lines
            [[ "$line" =~ ^#.*$ ]] && continue
            [[ -z "$line" ]] && continue

            # Expand ~ to $HOME
            line="${line/#\~/$HOME}"

            # Bare paths (no glob chars) are also offered as themselves
            if [[ "$line" != *[*?\[]* ]]; then
                extra_paths="${extra_paths}${line}"$'\n'
            fi

            if [[ -n "$default_directories" ]]; then
                default_directories="$default_directories "
            fi
            default_directories="$default_directories$line"
        done < "$tsp_file"
    fi

    # Fallback to hardcoded defaults if .tsp doesn't exist or is empty
    if [[ -z "$default_directories" ]]; then
        default_directories="$HOME/projects/* $HOME/.dotfiles"
        extra_paths="$HOME/.dotfiles"$'\n'
    fi

    selected=$({
        [[ -n "$extra_paths" ]] && printf '%s' "$extra_paths"
        eval "find $default_directories -mindepth 1 -maxdepth 1 -type d"
    } | fzf)
fi

if [[ -z $selected ]]; then
    echo "nothing selected"
    exit 0
fi

selected_name=$(basename "$selected" | tr . _)
# Check if tmux is running (pgrep may not be available on all systems)
if command -v pgrep >/dev/null 2>&1; then
    tmux_running=$(pgrep tmux)
else
    tmux_running=$(ps aux | grep -v grep | grep -c tmux)
    [[ "$tmux_running" -gt 0 ]] && tmux_running="1"
fi

echo "SELECTED: $selected, $selected_name"

if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
    tmux new-session -s $selected_name -c $selected
    echo "Created session $selected_name, $selected"
    exit 0
fi

if ! tmux has-session -t $selected_name 2> /dev/null; then
    tmux new-session -ds $selected_name -c $selected
    echo "Added session $selected_name, $selected"
fi

tmux switch-client -t $selected_name
